# Things that should never end up in the Lambda image.
.git
.gitignore
.venv
.env
.env.example
.pytest_cache
.ruff_cache
.mypy_cache
__pycache__
*.pyc
*.pyo
*.log

# Local-only / dev-only directories.
checkpoints/
corpus/
demos/
evals/
tests/
docs/
assets/
.claude/
.vscode/
.idea/

# Build artifacts.
*.zip
*.tar.gz
build/
dist/
*.egg-info

# Docs / project files not needed at runtime.
README.md
*.md
Dockerfile
.dockerignore
deploy.sh

# CLI/scraper scripts not needed in Lambda runtime.
cli.py
scrape_corpus.py
ingest.py
query.py
